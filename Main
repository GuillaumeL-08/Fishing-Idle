# Créer une fenêtre tkinter avec fond transparent
root = tk.Tk()
root.overrideredirect(True)  # Pas de bordure
root.attributes('-topmost', True)  # Toujours au-dessus
root.attributes('-transparentcolor', 'black')  # Noir = transparent
root.attributes('-alpha', 0.9)  # Légère transparence
root.geometry("300x300+500+300")

# Canvas pour dessiner
canvas = Canvas(root, width=300, height=300, bg='black', highlightthickness=0)
canvas.pack()

# Variables de position
x, y = 150,150
dragging = False
drag_start_x = 0
drag_start_y = 0

# Variables pour l'image
character_image = None
photo_image = None
rotated_photo_image = None

# Variables pour le mode pêche
fishing_mode = False
fishing_rod = None
fish = None
fishing_timer = None

# Variables pour le système gacha
gacha_active = False
next_fish_time = 0
fish_collection = {}
fishing_start_time = 0
gacha_timer = None

# Variables pour le système d'aura
animations = {}  # Dictionnaire pour stocker toutes les animations actives
next_animation_id = 1  # ID unique pour chaque animation

