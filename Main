# ═══════════════════════════════════════════════════════════════════════════════
# PARTICLE ANIMATIONS  (original system)
# ═══════════════════════════════════════════════════════════════════════════════
animations        = {}
next_animation_id = 1


class AnimationConfig:
    def __init__(self):
        self.cone_width     = 120
        self.base_radius    = 40
        self.point_radius   = 2
        self.particle_count = 25
        self.min_size       = 3
        self.max_size       = 8
        self.vx_min         = -0.8
        self.vx_max         =  0.8
        self.vy_min         = -0.1
        self.vy_max         =  0.1
        self.gravity        =  0.001
        self.life_duration  = 250
        self.stages = [
            {"life": 176, "stipple": "gray75"},
            {"life": 128, "stipple": "gray50"},
            {"life":  80, "stipple": "gray25"},
            {"life":  32, "shrink":  True},
        ]


animation_config = AnimationConfig()


class PerfectAnimation:
    def __init__(self, animation_id, color, ax, ay, config):
        self.id        = animation_id
        self.color     = color
        self.x         = ax
        self.y         = ay
        self.config    = config
        self.particles = []
        self.timer     = None
        self.active    = True
        self._create_particles()

    def _create_particles(self):
        for i in range(self.config.particle_count):
            wr = (i / self.config.particle_count) - 0.5
            cr = self.config.base_radius * (1 - abs(wr) * 1.5)
            if cr < self.config.point_radius:
                cr = self.config.point_radius
            cx2 = self.x + wr * self.config.cone_width
            cy2 = self.y + random.randint(-10, 10)
            if wr < 0:
                vx = random.uniform(self.config.vx_min, self.config.vx_min / 2)
            elif wr > 0:
                vx = random.uniform(self.config.vx_max / 2, self.config.vx_max)
            else:
                vx = random.uniform(self.config.vx_min / 3, self.config.vx_max / 3)
            vy      = random.uniform(self.config.vy_min, self.config.vy_max)
            size    = random.randint(self.config.min_size, self.config.max_size) * (1 - abs(wr))
            if size < 1:
                size = 1
            stipple = 'gray25' if abs(wr) < 0.2 else ('gray50' if abs(wr) < 0.4 else 'gray75')
            pid = canvas.create_oval(cx2 - size, cy2 - size, cx2 + size, cy2 + size,
                                     fill=self.color, outline='', stipple=stipple)
            self.particles.append({
                'id': pid, 'type': 'cone_dispersed',
                'x': cx2, 'y': cy2, 'vx': vx, 'vy': vy,
                'size': size, 'base_size': size,
                'life': self.config.life_duration,
                'max_life': self.config.life_duration,
            })

    def animate(self):
        if not self.active:
            return
        to_remove = []
        for p in self.particles:
            p['life'] -= 1
            if p['life'] <= 0:
                canvas.delete(p['id'])
                to_remove.append(p)
            else:
                p['x']  += p['vx']
                p['y']  += p['vy']
                p['vy'] += self.config.gravity
                lr   = p['life'] / p['max_life']
                size = p['base_size'] * lr
                for stage in self.config.stages:
                    if p['life'] < stage['life']:
                        if 'stipple' in stage:
                            canvas.itemconfig(p['id'], stipple=stage['stipple'])
                        elif 'shrink' in stage:
                            size = p['base_size'] * (0.3 + lr * 0.7)
                        break
                canvas.coords(p['id'], p['x'] - size, p['y'] - size,
                              p['x'] + size, p['y'] + size)
        for p in to_remove:
            self.particles.remove(p)
        if self.active and self.particles:
            self.timer = root.after(80, self.animate)
        elif not self.particles:
            self.stop()

    def stop(self):
        self.active = False
        if self.timer:
            root.after_cancel(self.timer)
        for p in self.particles:
            canvas.delete(p['id'])
        if self.id in animations:
            del animations[self.id]


def start_aura(rarity):
    global next_animation_id
    stop_aura()
    anim = PerfectAnimation(next_animation_id,
                            AURA_COLOR.get(rarity, '#808080'),
                            x, y, animation_config)
    animations[next_animation_id] = anim
    anim.animate()
    next_animation_id += 1


def stop_aura():
    for aid in list(animations.keys()):
        animations[aid].stop()


# ═══════════════════════════════════════════════════════════════════════════════
# CATCH DISPLAY  (spinning fish + glow + info card above character)
# ═══════════════════════════════════════════════════════════════════════════════
class CatchDisplay:
    DURATION_MS = 4500  # total display time

    def __init__(self, fish):
        self.fish       = fish
        self.items      = []
        self.frame_idx  = 0
        self.tick       = 0
        self.timer      = None
        self.active     = True
        self.frames     = _ROT_FRAMES.get(fish['name'], [])
        self._step()
        root.after(self.DURATION_MS, self.stop)

    def _step(self):
        if not self.active:
            return

        # clear previous frame items
        for cid in self.items:
            canvas.delete(cid)
        self.items = []

        rc   = RARITY_COLOR.get(self.fish['rarity'], '#AAAAAA')
        cx2  = x
        cy2  = y - 195   # above character

        # ── pulsing glow rings ──
        pulse = abs(math.sin(self.tick * 0.25))
        for r_off, stip in [(46, 'gray12'), (38, 'gray25'), (30, 'gray50')]:
            rr = r_off + int(pulse * 4)
            self.items.append(
                canvas.create_oval(cx2-rr, cy2-rr, cx2+rr, cy2+rr,
                                   fill=rc, outline='', stipple=stip)
            )

        # shiny sparkles orbiting
        if self.fish.get('shiny'):
            for k in range(6):
                ang = math.radians(self.tick * 12 + k * 60)
                sx  = cx2 + int(42 * math.cos(ang))
                sy  = cy2 + int(42 * math.sin(ang))
                self.items.append(canvas.create_oval(sx-3, sy-3, sx+3, sy+3,
                                                     fill='#FFEE44', outline=''))

        # spinning fish image
        if self.frames:
            frame = self.frames[self.frame_idx % len(self.frames)]
            self.items.append(canvas.create_image(cx2, cy2, image=frame))
            self.frame_idx += 1
        else:
            # fallback: colored rectangle
            self.items.append(canvas.create_rectangle(cx2-28, cy2-28, cx2+28, cy2+28,
                                                       fill=rc, outline=''))

        # ── info card ──
        mods = []
        if self.fish.get('shiny'):   mods.append('✦ SHINY')
        if self.fish.get('antique'): mods.append('ANTIQUE')
        if self.fish.get('abyssal'): mods.append('ABYSSAL')
        if self.fish.get('albinos'): mods.append('ALBINOS')
        if self.fish.get('malade'):  mods.append('MALADE')
        mod_line = '  '.join(mods)

        lines = [self.fish['name']]
        lines.append(f"{self.fish['size']} cm")
        if mod_line:
            lines.append(mod_line)
        lines.append(f"{self.fish['value']} or")
        text = '\n'.join(lines)

        n_lines = len(lines)
        bh      = 14 * n_lines + 10
        tx, ty  = cx2, cy2 + 45
        self.items.append(
            canvas.create_rectangle(tx-68, ty-4, tx+68, ty+bh,
                                    fill='#0A0A18', outline=rc, width=2)
        )
        self.items.append(
            canvas.create_text(tx, ty + bh//2 - 2, text=text, fill=rc,
                               font=('Arial', 8, 'bold'), justify='center')
        )

        self.tick  += 1
        self.timer  = root.after(70, self._step)

    def stop(self):
        self.active = False
        if self.timer:
            root.after_cancel(self.timer)
        for cid in self.items:
            canvas.delete(cid)
        self.items = []
        global _catch_display
        if _catch_display is self:
            _catch_display = None


# ═══════════════════════════════════════════════════════════════════════════════
# IMAGE & CHARACTER
# ═══════════════════════════════════════════════════════════════════════════════
def load_image():
    global character_image, photo_image
    img_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'images', 'image.png')
    try:
        character_image = Image.open(img_path).resize((250, 250), Image.Resampling.LANCZOS)
        photo_image     = ImageTk.PhotoImage(character_image)
        return True
    except Exception as e:
        print(f"Erreur image personnage: {e}")
    return False


def draw_character():
    canvas.delete("char")
    if photo_image:
        canvas.create_image(x, y, image=photo_image, tags="char")

    # Auto-fish indicator (cyan  dot)
    if auto_fish_active:
        canvas.create_oval(x+80, y-110, x+96, y-94,
                           fill='#00CCFF', outline='', tags="char")



def draw_fishing_gear():
    canvas.delete("rod")
    for i in range(3):
        by2 = y + 80 + i * 15
        bx2 = x + 80 + random.randint(-10, 10)
        canvas.create_oval(bx2-3, by2-3, bx2+3, by2+3,
                           fill='darkblue', outline='blue', tags="rod")


# ═══════════════════════════════════════════════════════════════════════════════
# RNG
# ═══════════════════════════════════════════════════════════════════════════════
def base_luck():
    return luck_level * 5


def roll_fish(luck_bonus):
    rod     = ROD_TIERS[rod_tier]
    lk      = min(luck_bonus, 50)
    peu_c_w = 40 + rod['peu_c_b'] + lk * 0.30
    rare_w  = 25 + rod['rare_b'] + lk * 0.20
    epic_w  = 10 + rod['epic_b'] + lk * 0.15
    leg_w   =  5 + rod['leg_b']  + lk * 0.10
    myt_w   =  3 + rod['myt_b']  + lk * 0.10
    lev_w  =  0.5 + lk * 0.08
    other   = peu_c_w + rare_w + epic_w + leg_w + myt_w + lev_w
    comm_w  = max(60.0, (2/3) * other)

    rarity = random.choices(
        ['Commun', 'Peu Commun', 'Rare', 'Épique', 'Légendaire', 'Mythique', 'LEVIATHAN'],
        weights=[comm_w, peu_c_w, rare_w, epic_w, leg_w, myt_w, lev_w], k=1
    )[0]

    # Pick a fish of that rarity, with fallback to any rarity if pool is empty
    pool = [f for f in FISH_DEFS if f['rarity'] == rarity]
    if not pool:
        pool = FISH_DEFS
    defn    = random.choice(pool)
    size    = round(random.uniform(defn['min_sz'], defn['max_sz']), 1)
    shiny   = random.random() < 0.01
    antique = random.random() < 0.03
    abyssal = random.random() < 0.05
    albinos = random.random() < 0.1
    malade  = random.random() < 0.02
    value   = int(
        defn['base_val']
        * (0.5 + size / defn['max_sz'])
        * (10 if shiny   else 1)
        * (5  if antique else 1)
        * (2  if abyssal else 1)
        * (1.5  if albinos else 1)
        * (0.8  if malade else 1)
    )
    return dict(name=defn['name'], rarity=rarity, size=size,
                shiny=shiny, antique=antique, abyssal=abyssal, value=value)


# ═══════════════════════════════════════════════════════════════════════════════
# FISHING
# ═══════════════════════════════════════════════════════════════════════════════
def _start_cast():
    """Internal: begin one fishing cast (used by both manual and auto modes)."""
    global fishing_mode, fishing_start_time, fish_duration, gacha_timer
    fishing_mode       = True
    fishing_start_time = time.time()
    fish_duration      = random.uniform(10, 50)
    gacha_timer        = root.after(int(fish_duration * 1000), do_catch)
    _animate_rod()


def toggle_fishing():
    global fishing_mode, gacha_timer, fishing_anim_id, auto_fish_active

    if fishing_mode:
        # Cancel current cast (also disables auto-fish)
        auto_fish_active = False
        fishing_mode = False
        if gacha_timer:
            root.after_cancel(gacha_timer)
            gacha_timer = None
        if fishing_anim_id:
            root.after_cancel(fishing_anim_id)
            fishing_anim_id = None
        canvas.delete("rod")
        draw_character()
        return

    if len(inventory) >= inv_capacity:
        show_overlay("Inventaire plein !", '#FF4444')
        return

    _start_cast()


def toggle_auto_fish(event=None):
    """Space key: toggle auto-fishing (only if upgrade purchased)."""
    global auto_fish_active
    if not auto_fish_unlocked:
        return
    auto_fish_active = not auto_fish_active
    if auto_fish_active and not fishing_mode:
        if len(inventory) < inv_capacity:
            _start_cast()
        else:
            show_overlay("Inventaire plein !", '#FF4444')
            auto_fish_active = False
    draw_character()


def do_catch():
    global fishing_mode, gacha_timer, coins, fishing_anim_id, _catch_display

    fishing_mode    = False
    gacha_timer     = None
    fishing_anim_id = None

    elapsed    = time.time() - fishing_start_time
    prog       = min(elapsed / fish_duration, 1.0)
    luck_bonus = base_luck() + prog * 30
    fish       = roll_fish(luck_bonus)

    canvas.delete("rod")

    if len(inventory) < inv_capacity:
        inventory.append(fish)

        # Launch spinning catch display
        if _catch_display:
            _catch_display.stop()
        _catch_display = CatchDisplay(fish)

        start_aura(fish['rarity'])
        mods = (''.join([
            ' ✦SHINY' if fish['shiny'] else '',
            ' ANTIQUE' if fish['antique'] else '',
            ' ABYSSAL' if fish['abyssal'] else '',
        ])).strip()
        print(f"Pêché : {fish['name']} {mods}  {fish['size']}cm  +{fish['value']}or")
    else:
        show_overlay("Inventaire plein !\nPoisson relâché.", '#FF4444')

    save_game()
    draw_character()
    _refresh_windows()

    # Auto-fish: restart cast after a short pause
    global auto_fish_active
    if auto_fish_active and len(inventory) < inv_capacity:
        root.after(1500, _start_cast)
    elif auto_fish_active and len(inventory) >= inv_capacity:
        auto_fish_active = False
        show_overlay("Auto-pêche arrêtée\n(sac plein)", '#FF8800')
        draw_character()


def _animate_rod():
    global fishing_anim_id
    if fishing_mode:
        draw_fishing_gear()
        draw_character()
        fishing_anim_id = root.after(500, _animate_rod)


# ═══════════════════════════════════════════════════════════════════════════════
# OVERLAY MESSAGE
# ═══════════════════════════════════════════════════════════════════════════════
def show_overlay(text, color='#FFD700'):
    global _overlay_ids, _overlay_timer
    for oid in _overlay_ids:
        canvas.delete(oid)
    if _overlay_timer:
        root.after_cancel(_overlay_timer)
    lines = text.count('\n') + 1
    bh    = 22 * lines + 10
    bx1, by1, bx2, by2 = x - 95, y + 128, x + 95, y + 128 + bh
    _overlay_ids = [
        canvas.create_rectangle(bx1, by1, bx2, by2, fill='#0E0E1A', outline=color, width=2),
        canvas.create_text(x, (by1 + by2) // 2, text=text, fill=color,
                           font=('Arial', 10, 'bold'), justify='center'),
    ]
    _overlay_timer = root.after(3500, _clear_overlay)


def _clear_overlay():
    global _overlay_ids, _overlay_timer
    for oid in _overlay_ids:
        canvas.delete(oid)
    _overlay_ids   = []
    _overlay_timer = None


# ═══════════════════════════════════════════════════════════════════════════════
# POPUP HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
BG   = '#0E0E1A'
BG2  = '#16162A'
BG3  = '#1E1E35'
FG   = '#DDDDEE'
ACC  = '#FFD700'
GRAY = '#666688'


def _make_popup(title, w, h, ox=310, oy=0):
    win = tk.Toplevel(root)
    win.overrideredirect(True)
    win.attributes('-topmost', True)
    win.geometry(f"{w}x{h}+{root.winfo_x()+ox}+{root.winfo_y()+oy}")
    win.configure(bg=BG)

    tb = tk.Frame(win, bg='#1A1A30', height=28)
    tb.pack(fill='x')
    tb.pack_propagate(False)

    def _ds(e): win._dx, win._dy = e.x, e.y
    def _dm(e): win.geometry(f"+{win.winfo_x()+e.x-win._dx}+{win.winfo_y()+e.y-win._dy}")
    tb.bind('<Button-1>', _ds)
    tb.bind('<B1-Motion>', _dm)

    tk.Label(tb, text=title, bg='#1A1A30', fg=ACC,
             font=('Arial', 11, 'bold')).pack(side='left', padx=8, pady=4)
    tk.Button(tb, text='✕', bg='#1A1A30', fg='#888888', relief='flat',
              cursor='hand2', font=('Arial', 10),
              activebackground='#3A1A1A', activeforeground='#FF6666',
              command=win.destroy).pack(side='right', padx=6, pady=2)

    win.bind('<Destroy>', lambda _e: root.focus_force() if _e.widget is win else None)
    win.bind('b', open_shop)
    win.bind('B', open_shop)
    win.bind('e', open_inventory)
    win.bind('E', open_inventory)
    win.bind('c', open_catalogue)
    win.bind('C', open_catalogue)
    win.bind('<space>', toggle_auto_fish)
    win.bind('<Escape>', lambda e: win.destroy())
    win.focus_force()
    return win


def _btn(parent, text, cmd, bg='#1A3A1A', fg=FG, w=12):
    return tk.Button(parent, text=text, command=cmd, bg=bg, fg=fg,
                     activebackground='#333355', activeforeground=FG,
                     relief='flat', cursor='hand2',
                     font=('Arial', 9, 'bold'), width=w, pady=4)


def _refresh_windows():
    if _shop_win and _shop_win.winfo_exists():
        _build_shop(_shop_win)
    if _inv_win and _inv_win.winfo_exists():
        _build_inventory(_inv_win)
    if _cat_win and _cat_win.winfo_exists():
        _build_catalogue(_cat_win)


# ═══════════════════════════════════════════════════════════════════════════════
# SHOP  (key B)
# ═══════════════════════════════════════════════════════════════════════════════
def open_shop(event=None):
    global _shop_win
    if _shop_win and _shop_win.winfo_exists():
        _shop_win.lift(); return
    _shop_win = _make_popup("Boutique", 340, 480)
    _build_shop(_shop_win)


def _build_shop(win):
    for w in list(win.winfo_children())[1:]:
        w.destroy()

    body = tk.Frame(win, bg=BG)
    body.pack(fill='both', expand=True, padx=8, pady=6)

    tk.Label(body, text=f"Or disponible : {coins}", bg=BG, fg=ACC,
             font=('Arial', 11, 'bold')).pack(anchor='e', padx=4, pady=(0, 4))

    # ── Rods ──
    tk.Label(body, text="── Cannes à pêche ──", bg=BG, fg='#AA7733',
             font=('Arial', 9, 'bold')).pack(pady=(4, 2))

    for i, rod in enumerate(ROD_TIERS[1:], start=1):
        owned    = rod_tier >= i
        unlocked = rod_tier >= i - 1
        aff      = coins >= rod['price'] and not owned and unlocked

        row = tk.Frame(body, bg=BG2)
        row.pack(fill='x', pady=2, padx=2)

        fg_col = '#66CC66' if owned else (FG if unlocked else GRAY)
        tk.Label(row, text=rod['name'], bg=BG2, fg=fg_col,
                 font=('Arial', 9, 'bold'), width=15, anchor='w').pack(side='left', padx=6, pady=5)
        if owned:
            tk.Label(row, text="✓", bg=BG2, fg='#66CC66',
                     font=('Arial', 9, 'bold')).pack(side='right', padx=8)
        elif not unlocked:
            tk.Label(row, text="🔒", bg=BG2, fg=GRAY,
                     font=('Arial', 9)).pack(side='right', padx=8)
        else:
            def _buy(idx=i):
                global coins, rod_tier
                if coins >= ROD_TIERS[idx]['price'] and rod_tier == idx - 1:
                    coins -= ROD_TIERS[idx]['price']
                    rod_tier = idx
                    save_game()
                    draw_character()
                    _build_shop(win)
            b = _btn(row, f"{rod['price']} or", _buy,
                     bg='#1E2E1E' if aff else BG3, fg=ACC if aff else GRAY, w=10)
            b.config(state='normal' if aff else 'disabled')
            b.pack(side='right', padx=6, pady=4)

    # ── Upgrades ──
    tk.Label(body, text="── Améliorations ──", bg=BG, fg='#33AACC',
             font=('Arial', 9, 'bold')).pack(pady=(10, 2))

    # Inventory
    inv_lvl   = (inv_capacity - 10) // 5
    inv_price = int(150 * (2.5 ** inv_lvl))
    inv_max   = inv_capacity >= 30
    inv_aff   = coins >= inv_price and not inv_max

    row_inv = tk.Frame(body, bg=BG2)
    row_inv.pack(fill='x', pady=2, padx=2)
    tk.Label(row_inv, text=f"Inventaire +5   ({inv_capacity}/30)",
             bg=BG2, fg=FG, font=('Arial', 9), width=22, anchor='w').pack(side='left', padx=6, pady=5)
    if inv_max:
        tk.Label(row_inv, text="MAX", bg=BG2, fg='#66CC66',
                 font=('Arial', 8, 'bold')).pack(side='right', padx=8)
    else:
        def _buy_inv():
            global coins, inv_capacity
            p = int(150 * (2.5 ** ((inv_capacity - 10) // 5)))
            if coins >= p and inv_capacity < 30:
                coins -= p
                inv_capacity += 5
                save_game()
                draw_character()
                _build_shop(win)
        b2 = _btn(row_inv, f"{inv_price} or", _buy_inv,
                  bg='#1A1A2E' if inv_aff else BG3, fg=ACC if inv_aff else GRAY, w=10)
        b2.config(state='normal' if inv_aff else 'disabled')
        b2.pack(side='right', padx=6, pady=4)

    # Luck charm
    luck_price = int(300 * (2.0 ** luck_level))
    luck_aff   = coins >= luck_price

    row_luck = tk.Frame(body, bg=BG2)
    row_luck.pack(fill='x', pady=2, padx=2)
    tk.Label(row_luck, text=f"Charme de Chance  niv.{luck_level}  (+{base_luck()}%)",
             bg=BG2, fg=FG, font=('Arial', 9), width=28, anchor='w').pack(side='left', padx=6, pady=5)

    def _buy_luck():
        global coins, luck_level
        p = int(300 * (2.0 ** luck_level))
        if coins >= p:
            coins -= p
            luck_level += 1
            save_game()
            draw_character()
            _build_shop(win)
    b3 = _btn(row_luck, f"{luck_price} or", _buy_luck,
              bg='#1E1228' if luck_aff else BG3, fg=ACC if luck_aff else GRAY, w=10)
    b3.config(state='normal' if luck_aff else 'disabled')
    b3.pack(side='right', padx=6, pady=4)

    # Auto-fish
    AUTO_PRICE = 100
    af_aff  = coins >= AUTO_PRICE and not auto_fish_unlocked

    row_af = tk.Frame(body, bg=BG2)
    row_af.pack(fill='x', pady=2, padx=2)
    af_name = "Auto-Pêche  [Espace]"
    tk.Label(row_af, text=af_name, bg=BG2, fg=('#00CCFF' if auto_fish_unlocked else FG),
             font=('Arial', 9, 'bold' if auto_fish_unlocked else 'normal'),
             width=22, anchor='w').pack(side='left', padx=6, pady=2)

    if auto_fish_unlocked:
        status = "✓ Débloquée"
        tk.Label(row_af, text=status, bg=BG2, fg='#00CCFF',
                 font=('Arial', 8, 'bold')).pack(side='right', padx=8, pady=5)
    else:
        def _buy_af():
            global coins, auto_fish_unlocked
            if coins >= AUTO_PRICE and not auto_fish_unlocked:
                coins -= AUTO_PRICE
                auto_fish_unlocked = True
                save_game()
                draw_character()
                _build_shop(win)
        b4 = _btn(row_af, f"{AUTO_PRICE} or", _buy_af,
                  bg='#1A1A2E' if af_aff else BG3, fg='#00CCFF' if af_aff else GRAY, w=10)
        b4.config(state='normal' if af_aff else 'disabled')
        b4.pack(side='right', padx=6, pady=4)


# ═══════════════════════════════════════════════════════════════════════════════
# INVENTORY  (key E)  — image thumbnails + modifier badges
# ═══════════════════════════════════════════════════════════════════════════════
_inv_sel = [None]   # mutable container so inner funcs can write it


def open_inventory(event=None):
    global _inv_win
    if _inv_win and _inv_win.winfo_exists():
        _build_inventory(_inv_win); _inv_win.lift(); return
    _inv_win = _make_popup("Inventaire", 360, 450, ox=310, oy=0)
    _build_inventory(_inv_win)


def _build_inventory(win):
    _inv_sel[0] = None
    for w in list(win.winfo_children())[1:]:
        w.destroy()

    body = tk.Frame(win, bg=BG)
    body.pack(fill='both', expand=True, padx=6, pady=4)

    tk.Label(body, text=f"Inventaire  {len(inventory)} / {inv_capacity}",
             bg=BG, fg=FG, font=('Arial', 11, 'bold')).pack(anchor='w', pady=(0, 3))

    # ── Scrollable canvas list ──
    outer = tk.Frame(body, bg=BG)
    outer.pack(fill='both', expand=True)
    vsb = tk.Scrollbar(outer, orient='vertical', bg=BG, troughcolor=BG2, width=10)
    vsb.pack(side='right', fill='y')
    cav = tk.Canvas(outer, bg=BG, highlightthickness=0, yscrollcommand=vsb.set)
    cav.pack(side='left', fill='both', expand=True)
    vsb.config(command=cav.yview)

    inner = tk.Frame(cav, bg=BG)
    wid   = cav.create_window((0, 0), window=inner, anchor='nw')

    def _resize(e):
        cav.configure(scrollregion=cav.bbox('all'))
    def _cav_resize(e):
        cav.itemconfig(wid, width=e.width)
    inner.bind('<Configure>', _resize)
    cav.bind('<Configure>', _cav_resize)
    cav.bind('<MouseWheel>', lambda e: cav.yview_scroll(-1*(e.delta//120), 'units'))

    row_frames = []

    def _select(idx):
        _inv_sel[0] = idx
        for i2, rf in enumerate(row_frames):
            rf.config(bg='#2A2A4A' if i2 == idx else (BG2 if i2 % 2 == 0 else BG3))
            for child in rf.winfo_children():
                _recolor(child, '#2A2A4A' if i2 == idx else (BG2 if i2 % 2 == 0 else BG3))
        _update_sell_btn()

    def _recolor(widget, bg):
        try:
            widget.config(bg=bg)
        except Exception:
            pass
        for child in widget.winfo_children():
            _recolor(child, bg)

    for i, fish in enumerate(inventory):
        rc      = RARITY_COLOR.get(fish['rarity'], '#AAA')
        row_bg  = BG2 if i % 2 == 0 else BG3
        row     = tk.Frame(inner, bg=row_bg, cursor='hand2')
        row.pack(fill='x', pady=0, padx=2)
        row_frames.append(row)

        # Thumbnail
        if fish['name'] in FISH_IMAGES_SM:
            img_lbl = tk.Label(row, image=FISH_IMAGES_SM[fish['name']], bg=row_bg)
            img_lbl.pack(side='left', padx=4, pady=3)
            img_lbl.bind('<Button-1>', lambda e, idx=i: _select(idx))

        # Name + rarity
        name_col = rc
        name_txt = fish['name']
        tk.Label(row, text=name_txt, bg=row_bg, fg=name_col,
                 font=('Arial', 9, 'bold'), width=14, anchor='w').pack(side='left', padx=2)

        # Modifier badges
        badge_frame = tk.Frame(row, bg=row_bg)
        badge_frame.pack(side='left')
        if fish.get('shiny'):
            tk.Label(badge_frame, text='SHI', bg='#664400', fg='#FFDD55',
                     font=('Arial', 7, 'bold'), padx=1).pack(side='left', padx=1)
        if fish.get('antique'):
            tk.Label(badge_frame, text='ANT', bg='#4A2A00', fg='#FFAA44',
                     font=('Arial', 7, 'bold'), padx=1).pack(side='left', padx=1)
        if fish.get('abyssal'):
            tk.Label(badge_frame, text='ABY', bg='#001A3A', fg='#44AAFF',
                     font=('Arial', 7, 'bold'), padx=1).pack(side='left', padx=1)
        if fish.get('albinos'):
            tk.Label(badge_frame, text='ALB', bg='#001A3A', fg='#44AAFF',
                     font=('Arial', 7, 'bold'), padx=1).pack(side='left', padx=1)
        if fish.get('malade'):
            tk.Label(badge_frame, text='MAL', bg='#3A0000', fg='#FF4444',
                     font=('Arial', 7, 'bold'), padx=1).pack(side='left', padx=1)

        # Size + value
        tk.Label(row, text=f"{fish['size']}cm", bg=row_bg, fg=GRAY,
                 font=('Arial', 8,'bold'), width=7, anchor='e').pack(side='left')
        tk.Label(row, text=f"{fish['value']} or", bg=row_bg, fg=ACC,
                 font=('Arial', 8, 'bold'), width=7, anchor='e').pack(side='left', padx=1)

        row.bind('<Button-1>', lambda e, idx=i: _select(idx))

    # ── Bottom bar ──
    bot = tk.Frame(body, bg=BG)
    bot.pack(fill='x', pady=(5, 0))

    sell_var = tk.StringVar(value="Vendre")
    sell_btn = _btn(bot, "Vendre", lambda: None, bg='#1A3A1A', w=14)
    sell_btn.pack(side='left', padx=4)
    sell_btn.config(state='disabled')

    total_val = sum(f['value'] for f in inventory)
    _btn(bot, f"Tout vendre ({total_val}or)", _sell_all_fn(win), bg='#3A2800', fg=ACC, w=18).pack(side='right', padx=4)

    def _update_sell_btn():
        idx = _inv_sel[0]
        if idx is not None and idx < len(inventory):
            f = inventory[idx]
            sell_btn.config(
                text=f"Vendre {f['value']}or",
                state='normal',
                command=lambda: _sell_one_fn(win, idx)
            )
        else:
            sell_btn.config(text="Vendre", state='disabled', command=lambda: None)

    _update_sell_btn()


def _update_catalogue(fish):
    entry = catalogue[fish['name']]
    entry['count'] += 1
    if entry['best'] is None or fish['value'] > entry['best']['value']:
        entry['best'] = fish


def _sell_one_fn(win, idx):
    global coins
    if idx < len(inventory):
        fish = inventory.pop(idx)
        coins += fish['value']
        _update_catalogue(fish)
        save_game()
        draw_character()
        show_overlay(f"+{fish['value']} or", ACC)
        _refresh_windows()


def _sell_all_fn(win):
    def _do():
        global coins
        if not inventory:
            return
        total = sum(f['value'] for f in inventory)
        for fish in inventory:
            _update_catalogue(fish)
        inventory.clear()
        coins += total
        save_game()
        draw_character()
        show_overlay(f"+{total} or  (tout vendu)", ACC)
        _refresh_windows()
    return _do


# ═══════════════════════════════════════════════════════════════════════════════
# CATALOGUE  (key C)  — with fish images
# ═══════════════════════════════════════════════════════════════════════════════
def open_catalogue(event=None):
    global _cat_win
    if _cat_win and _cat_win.winfo_exists():
        _build_catalogue(_cat_win); _cat_win.lift(); return
    _cat_win = _make_popup("Catalogue", 440, 520, ox=-450, oy=0)
    _build_catalogue(_cat_win)


def _build_catalogue(win):
    for w in list(win.winfo_children())[1:]:
        w.destroy()

    body = tk.Frame(win, bg=BG)
    body.pack(fill='both', expand=True, padx=6, pady=4)

    unlocked = sum(1 for d in FISH_DEFS if catalogue[d['name']]['count'] > 0)
    tk.Label(body, text=f"Découverts : {unlocked} / {len(FISH_DEFS)}",
             bg=BG, fg=FG, font=('Arial', 10, 'bold')).pack(anchor='w', pady=(0, 5))

    outer = tk.Frame(body, bg=BG)
    outer.pack(fill='both', expand=True)
    vsb = tk.Scrollbar(outer, orient='vertical', bg=BG, troughcolor=BG2, width=10)
    vsb.pack(side='right', fill='y')
    cav = tk.Canvas(outer, bg=BG, highlightthickness=0, yscrollcommand=vsb.set)
    cav.pack(side='left', fill='both', expand=True)
    vsb.config(command=cav.yview)

    inner = tk.Frame(cav, bg=BG)
    wid   = cav.create_window((0, 0), window=inner, anchor='nw')

    def _on_cfg(e):
        cav.configure(scrollregion=cav.bbox('all'))
    def _on_cav(e):
        cav.itemconfig(wid, width=e.width)
    inner.bind('<Configure>', _on_cfg)
    cav.bind('<Configure>', _on_cav)

    def _scroll(e):
        cav.yview_scroll(-1 * (e.delta // 120), 'units')

    def _bind_scroll(widget):
        widget.bind('<MouseWheel>', _scroll)
        for child in widget.winfo_children():
            _bind_scroll(child)

    COLS     = 3
    CARD_W   = 126
    CARD_H   = 148

    for idx, defn in enumerate(FISH_DEFS):
        col_n = idx % COLS
        row_n = idx // COLS
        entry = catalogue[defn['name']]
        found = entry['count'] > 0
        rc    = RARITY_COLOR.get(defn['rarity'], '#AAA')
        border = rc if found else '#2A2A44'

        card = tk.Frame(inner, bg=BG2, highlightbackground=border, highlightthickness=1,
                        width=CARD_W, height=CARD_H)
        card.pack_propagate(False)
        card.grid(row=row_n, column=col_n, padx=5, pady=5, sticky='nsew')
        inner.columnconfigure(col_n, weight=1)

        # Rarity badge
        badge_bg = border if found else '#1A1A2A'
        tk.Label(card, text=defn['rarity'], bg=badge_bg,
                 fg='#111' if found else (rc if defn['rarity'] != 'Commun' else '#333355'),
                 font=('Arial', 7, 'bold')).pack(fill='x')

        if found:
            img = FISH_IMAGES_MD.get(defn['name'])
            if img:
                tk.Label(card, image=img, bg=BG2).pack(pady=(3, 0))
            tk.Label(card, text=defn['name'], bg=BG2, fg=rc,
                     font=('Arial', 8, 'bold'), wraplength=CARD_W - 4).pack(pady=(2, 0))
            best = entry['best']
            if best:
                mods = ' '.join(filter(None, [
                    '✦' if best.get('shiny')   else '',
                    'ANT' if best.get('antique') else '',
                    'ABY' if best.get('abyssal') else '',
                ]))
                if mods:
                    tk.Label(card, text=mods, bg=BG2, fg='#FFEE44',
                             font=('Arial', 7, 'bold')).pack()
                tk.Label(card, text=f"{best['size']} cm · {best['value']} or",
                         bg=BG2, fg=ACC, font=('Arial', 7, 'bold')).pack()
            tk.Label(card, text=f"× {entry['count']} pêché(s)", bg=BG2, fg='#556655',
                     font=('Arial', 7)).pack(pady=(1, 0))
        else:
            img = LOCKED_IMAGE
            if img:
                tk.Label(card, image=img, bg=BG2).pack(pady=(3, 0))
            tk.Label(card, text="???", bg=BG2, fg='#2A2A44',
                     font=('Arial', 11, 'bold')).pack(pady=(2, 1))
            tk.Label(card, text="Non découvert", bg=BG2, fg='#333355',
                     font=('Arial', 7)).pack()

    # Bind scroll to all widgets so hovering over a card still scrolls
    win.update_idletasks()
    _bind_scroll(inner)


# ═══════════════════════════════════════════════════════════════════════════════
# DRAG & CLICK
# ═══════════════════════════════════════════════════════════════════════════════
def _hit_test(ex, ey):
    if photo_image:
        return (x - 125 <= ex <= x + 125) and (y - 125 <= ey <= y + 125)
    return (ex - x) ** 2 + (ey - (y - 7)) ** 2 <= 900


def on_click(event):
    global dragging, did_drag, drag_start_x, drag_start_y
    if _hit_test(event.x, event.y):
        dragging     = True
        did_drag     = False
        drag_start_x = event.x_root - root.winfo_x()
        drag_start_y = event.y_root - root.winfo_y()


def on_drag(event):
    global did_drag
    if dragging:
        did_drag = True
        nx = event.x_root - drag_start_x
        ny = event.y_root - drag_start_y
        sw, sh = root.winfo_screenwidth(), root.winfo_screenheight()
        nx = max(-270, min(sw - 30, nx))
        ny = max(-270, min(sh - 30, ny))
        root.geometry(f"300x420+{nx}+{ny}")


def on_release(event):
    global dragging, did_drag
    if dragging and not did_drag:
        toggle_fishing()
    dragging = did_drag = False


def on_right_click(event):
    load_image()
    draw_character()


# ═══════════════════════════════════════════════════════════════════════════════
# KEY BINDINGS
# ═══════════════════════════════════════════════════════════════════════════════
def _cheat(event=None):
    global fishing_mode, fishing_start_time, fish_duration, gacha_timer
    if gacha_timer:
        root.after_cancel(gacha_timer)
        gacha_timer = None
    if not fishing_mode:
        fishing_mode       = True
        fishing_start_time = time.time() - 45
        fish_duration      = 50
    do_catch()


canvas.bind('<Button-1>',        on_click)
canvas.bind('<B1-Motion>',       on_drag)
canvas.bind('<ButtonRelease-1>', on_release)
canvas.bind('<Button-3>',        on_right_click)
root.bind('<Escape>',  lambda e: root.quit())
root.bind('b',         open_shop)
root.bind('B',         open_shop)
root.bind('e',         open_inventory)
root.bind('E',         open_inventory)
root.bind('c',         open_catalogue)
root.bind('C',         open_catalogue)
root.bind('t',         _cheat)
root.bind('T',         _cheat)
root.bind('<space>',   toggle_auto_fish)

# ═══════════════════════════════════════════════════════════════════════════════
# START
# ═══════════════════════════════════════════════════════════════════════════════
load_game()
load_image()
draw_character()
root.focus_force()
root.after(100, load_fish_images)

if __name__ == '__main__':
    print("PET PÊCHEUR ─────────────────────────────────")
    print("  Clic sur le chat   → Pêcher / Annuler")
    print("  Espace             → Toggle auto-pêche (si acheté)")
    print("  B                  → Boutique")
    print("  E                  → Inventaire")
    print("  C                  → Catalogue")
    print("  T                  → Pêche instantanée (triche)")
    print("  Clic droit         → Changer l'image")
    print("  Échap              → Quitter")
    print("─────────────────────────────────────────────")
    root.mainloop()
