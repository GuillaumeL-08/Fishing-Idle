# ═══════════════════════════════════════════════════════════════════════════════
# FISH IMAGES
# ═══════════════════════════════════════════════════════════════════════════════
FISH_IMAGES    = {}   # name -> PhotoImage 64×64  (catch display)
FISH_IMAGES_SM = {}   # name -> PhotoImage 64×64  (inventory rows)
FISH_IMAGES_MD = {}   # name -> PhotoImage 64×64  (catalogue cards)
_ROT_FRAMES    = {}   # name -> [PhotoImage, ...]  (spin animation)
LOCKED_IMAGE   = None # PhotoImage for undiscovered catalogue cards


def _fit_square(pil_img, size):
    """Resize image to fit within a square of `size` pixels, preserving aspect ratio, with transparent padding."""
    img = pil_img.convert('RGBA')
    img.thumbnail((size, size), Image.Resampling.LANCZOS)
    bg = Image.new('RGBA', (size, size), (0, 0, 0, 0))
    bg.paste(img, ((size - img.width) // 2, (size - img.height) // 2))
    return bg


def _make_spin_frames(pil_img, size=64, n=16):
    """Y-axis flip simulation: squish horizontally."""
    frames = []
    base = _fit_square(pil_img.convert('RGBA'), size)
    flip = base.transpose(Image.FLIP_LEFT_RIGHT)
    for i in range(n):
        scale_x = math.cos(i * 2 * math.pi / n)
        src     = base if scale_x >= 0 else flip
        w2      = max(2, int(abs(scale_x) * size))
        sq      = src.resize((w2, size), Image.Resampling.LANCZOS)
        bg      = Image.new('RGBA', (size, size), (0, 0, 0, 0))
        bg.paste(sq, ((size - w2) // 2, 0))
        frames.append(ImageTk.PhotoImage(bg))
    return frames


def load_fish_images():
    """Load each fish image from images/ subfolder using the img field in FISH_DEFS."""
    global LOCKED_IMAGE
    img_dir = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'images')
    # Load locked placeholder
    try:
        pil_lock = Image.open(os.path.join(img_dir, 'locked.png')).convert('RGBA')
        LOCKED_IMAGE = ImageTk.PhotoImage(_fit_square(pil_lock, 64))
    except Exception as e:
        print(f"Image locked.png manquante: {e}")
    # Load fish images
    for defn in FISH_DEFS:
        name  = defn['name']
        fpath = os.path.join(img_dir, defn['img'])
        try:
            pil = Image.open(fpath).convert('RGBA')
        except Exception as e:
            print(f"Image manquante pour {name}: {e}")
            continue
        FISH_IMAGES[name]    = ImageTk.PhotoImage(_fit_square(pil, 64))
        FISH_IMAGES_SM[name] = ImageTk.PhotoImage(_fit_square(pil, 64))
        FISH_IMAGES_MD[name] = ImageTk.PhotoImage(_fit_square(pil, 64))
        _ROT_FRAMES[name]    = _make_spin_frames(pil, size=92, n=16)

