# SAVE / LOAD
# ═══════════════════════════════════════════════════════════════════════════════
SAVE_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'save.json')


def save_game():
    data = {
        'coins':              coins,
        'inventory':          inventory,
        'inv_capacity':       inv_capacity,
        'rod_tier':           rod_tier,
        'luck_level':         luck_level,
        'auto_fish_unlocked': auto_fish_unlocked,
        'catalogue':          catalogue,
    }
    try:
        with open(SAVE_PATH, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
    except Exception as e:
        print(f"Erreur sauvegarde : {e}")


def load_game():
    global coins, inventory, inv_capacity, rod_tier, luck_level, auto_fish_unlocked, catalogue
    if not os.path.exists(SAVE_PATH):
        return
    try:
        with open(SAVE_PATH, 'r', encoding='utf-8') as f:
            data = json.load(f)
        coins              = data.get('coins', 0)
        inventory          = data.get('inventory', [])
        inv_capacity       = data.get('inv_capacity', 10)
        rod_tier           = data.get('rod_tier', 0)
        luck_level         = data.get('luck_level', 0)
        auto_fish_unlocked = data.get('auto_fish_unlocked', False)
        saved_cat          = data.get('catalogue', {})
        for name in catalogue:
            if name in saved_cat:
                catalogue[name] = saved_cat[name]
        print("Sauvegarde chargée.")
    except Exception as e:
        print(f"Erreur chargement sauvegarde : {e}")


